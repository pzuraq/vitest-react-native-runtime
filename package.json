{
  "name": "rn-test-runner",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "test-packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "check-types": "tsc --noEmit --project packages/vitest-react-native-runtime/tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "npm run build --workspace=vitest-react-native-runtime",
    "dev": "npm run dev --workspace=vitest-react-native-runtime",
    "test": "vitest run",
    "test:dev": "vitest"
  },
  "overrides": {
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "version": "1.0.0",
  "dependencies": {
    "@react-native/babel-preset": "^0.81.6",
    "@react-native/metro-config": "^0.85.0",
    "@vitest/expect": "^4.1.4",
    "@vitest/runner": "^4.1.4",
    "@vitest/utils": "^4.1.4",
    "chai": "^6.2.2",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
