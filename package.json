{
  "name": "rn-test-runner",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "test-packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "check-types": "tsc --noEmit --project packages/vitest-mobile/tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:all": "npm run lint && npm run check-types && npm run format:check",
    "build": "npm run build --workspace=vitest-mobile",
    "dev": "npm run dev --workspace=vitest-mobile",
    "test": "vitest run --project ios",
    "test:ios": "vitest run --project ios",
    "test:android": "vitest run --project android",
    "test:dev": "vitest --project ios",
    "test:dev:android": "vitest --project android",
    "release": "npm run build && changeset publish"
  },
  "overrides": {
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.4",
    "@types/connect": "^3.4.38",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "version": "1.0.0",
  "dependencies": {
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "^5.7.0"
  },
  "packageManager": "npm@11.12.1"
}
